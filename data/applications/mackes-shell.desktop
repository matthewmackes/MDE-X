[Desktop Entry]
Type=Application
Name=Mackes Shell
GenericName=Settings & Mesh
Comment=Unified XFCE control panel — settings, mesh networking, fleet management
Exec=mackes
Icon=mackes-shell
Terminal=false
Categories=Settings;System;X-XFCE-SettingsDialog;DesktopSettings;
Keywords=settings;preferences;control;panel;xfce;shell;mesh;tailscale;headscale;fleet;ansible;
StartupNotify=true
StartupWMClass=Mackes Shell
Actions=Wizard;Drawer;

[Desktop Action Wizard]
Name=Open setup wizard
Exec=mackes --wizard

[Desktop Action Drawer]
Name=Open notification drawer
Exec=mackes --drawer
